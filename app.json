{
  "expo": {
    "name": "FocusBuddy",
    "slug": "focusbuddy",
    "version": "1.0.0",
    "owner": "toprakpt1",
    "orientation": "portrait",
    "icon": "./assets/focusbuddy.png",
    "userInterfaceStyle": "light",
    "scheme": "focusbuddy",
    "splash": {
      "image": "./assets/focusbuddy.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.focusbuddy.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/focusbuddy.png",
        "backgroundColor": "#FFF8F0"
      },
      "package": "com.focusbuddy.app",
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "pan",
      "splash": {
        "image": "./assets/focusbuddy.png",
        "resizeMode": "contain",
        "backgroundColor": "#FFF8F0"
      }
    },
    "androidNavigationBar": {
      "backgroundColor": "#EBDFD0",
      "barStyle": "dark-content"
    },
    "web": {
      "favicon": "./assets/focusbuddy.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-navigation-bar",
        {
          "backgroundColor": "#EBDFD0",
          "barStyle": "dark",
          "visibility": "visible",
          "position": "relative"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "53cbb6f5-9f1b-4762-a6cc-5dbd2079406f"
      },
      "developer": {
        "name": "Toprak Talha Karcılar",
        "email": "toprakpt1@protonmail.com",
        "website": "https://github.com/toprakpt1"
      }
    }
  }
}
